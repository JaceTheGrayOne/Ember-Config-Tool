<Window x:Class="Ember_Config_Tool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Ember_Config_Tool.Controls"
        Title="Ember Config Tool"
        Width="1360"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ContentTitleBandStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="Padding" Value="24,14" />
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="SectionSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShellBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionHeaderBandStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="SectionHeadingStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentHotBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionRowBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CellLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="SwitchLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="PillStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource FieldBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActivePillStyle"
               TargetType="Border"
               BasedOn="{StaticResource PillStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
        </Style>

        <Style x:Key="BooleanSwitchClusterStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InlineBooleanRowVisibilityStyle" TargetType="{x:Type Grid}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowInlineLabel}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MasterBooleanRowVisibilityStyle" TargetType="{x:Type Grid}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowInlineLabel}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConfigBooleanRowStyle" TargetType="{x:Type Grid}">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ConfigNumberRowStyle" TargetType="{x:Type Grid}">
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ConfigTextRowStyle" TargetType="{x:Type Grid}">
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ConfigNumberTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource ConfigNumberEditorTextBoxStyle}">
            <Setter Property="Width" Value="132" />
        </Style>

        <Style x:Key="ConfigTextTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="240" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="ConfigComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="240" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="TableNumberTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource ConfigNumberEditorTextBoxStyle}">
            <Setter Property="Width" Value="92" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="TableCellTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="164" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="TableCellComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Width" Value="164" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ConfigTableRowStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ConfigTableCellStyle" TargetType="Border">
            <Setter Property="Width" Value="188" />
            <Setter Property="Margin" Value="0,0,14,12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#17150F" />
            <Setter Property="BorderBrush" Value="{StaticResource FocusRingBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusRingBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource FocusRingBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ButtonBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningBandStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="12"
                Margin="0,0,0,12">
            <Grid KeyboardNavigation.TabNavigation="Continue">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="ModFolderCommandBand"
                      Grid.Row="0"
                      MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="360" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding CurrentPath, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="14"
                             Margin="0,0,8,0" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Reload" Command="{Binding ReloadCommand}" />
                        <Button Content="Defaults" Command="{Binding ResetCommand}" />
                        <Button Content="Save"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="PresetCommandBand"
                      Grid.Row="1"
                      Margin="0,12,0,0"
                      MinWidth="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="292" MinWidth="210" />
                        <ColumnDefinition Width="220" MinWidth="170" />
                        <ColumnDefinition Width="*" MinWidth="280" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0" />

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Presets}"
                              SelectedItem="{Binding SelectedPreset}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,8,0" />

                    <Border Grid.Column="2"
                            Style="{StaticResource WarningBandStyle}"
                            Visibility="{Binding HasDeveloperWarning, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding DeveloperWarning}"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="38"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Save Preset" Command="{Binding SavePresetCommand}" MinWidth="110" />
                        <Button Content="Load Preset" Command="{Binding LoadPresetCommand}" MinWidth="110" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="292" MinWidth="260" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="8">
                <ListBox ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Background="{StaticResource PanelBackgroundBrush}"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0"
                         Padding="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinWidth="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding IconGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Label}"
                                           FontSize="14"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource AppBackgroundBrush}" />

            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="0"
                    MinWidth="0">
                <Grid MinWidth="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ContentTitleBandStyle}">
                        <TextBlock Text="{Binding SelectedGroup.Label}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   LineHeight="32"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SectionsItemsControl"
                                      ItemsSource="{Binding SelectedGroup.Sections}"
                                      Margin="18,14,18,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SectionSurfaceStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Style="{StaticResource SectionHeaderBandStyle}">
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Border Style="{StaticResource PillStyle}"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,0,10,0"
                                                            Visibility="{Binding HasBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding BadgeLabel}"
                                                                   Foreground="{StaticResource AccentHotBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="NoWrap" />
                                                    </Border>
                                                    <TextBlock Text="{Binding HeaderText}"
                                                               Style="{StaticResource SectionHeadingStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource SectionRowBorderStyle}">
                                                            <Grid MinWidth="0">
                                                                <Grid Visibility="{Binding IsScalar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <Grid Visibility="{Binding IsBoolean, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <Grid Style="{StaticResource MasterBooleanRowVisibilityStyle}">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Style="{StaticResource BooleanSwitchClusterStyle}">
                                                                                <CheckBox IsChecked="{Binding BooleanEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                          Style="{StaticResource ConfigBooleanSwitchStyle}" />
                                                                                <TextBlock Text="Enabled"
                                                                                           Style="{StaticResource SwitchLabelStyle}"
                                                                                           Margin="8,0,0,0" />
                                                                            </StackPanel>

                                                                            <Border Grid.Column="1"
                                                                                    Style="{StaticResource ActivePillStyle}"
                                                                                    Margin="16,0,0,0"
                                                                                    Visibility="{Binding HasExplicitOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="Active override"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="NoWrap" />
                                                                            </Border>
                                                                        </Grid>

                                                                        <Grid Style="{StaticResource InlineBooleanRowVisibilityStyle}">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="280" />
                                                                                <ColumnDefinition Width="150" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Margin="0,0,16,0"
                                                                                        VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding DisplayLabel}"
                                                                                           Style="{StaticResource SettingLabelStyle}" />
                                                                                <TextBlock Text="{Binding DependencyText}"
                                                                                           ToolTip="{Binding DependencyTechnicalText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Foreground="{StaticResource WarningBrush}"
                                                                                           Visibility="{Binding ShowInactiveDependencyWarning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,3,0,0" />
                                                                            </StackPanel>

                                                                            <StackPanel Grid.Column="1"
                                                                                        Style="{StaticResource BooleanSwitchClusterStyle}">
                                                                                <CheckBox IsChecked="{Binding BooleanEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                          Style="{StaticResource ConfigBooleanSwitchStyle}" />
                                                                                <TextBlock Text="Enabled"
                                                                                           Style="{StaticResource SwitchLabelStyle}"
                                                                                           Margin="8,0,0,0" />
                                                                            </StackPanel>

                                                                            <Border Grid.Column="2"
                                                                                    Style="{StaticResource ActivePillStyle}"
                                                                                    Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasExplicitOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="Active override"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="NoWrap" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </Grid>

                                                                    <Grid Visibility="{Binding IsNonBooleanScalar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <Grid Visibility="{Binding UsesSliderEditor, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                              Style="{StaticResource ConfigNumberRowStyle}">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="280" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Margin="0,0,16,0"
                                                                                        VerticalAlignment="Center">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <CheckBox IsChecked="{Binding OverrideActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              Visibility="{Binding UsesOverrideStateSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                              Margin="0,0,10,0" />
                                                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                                                               Style="{StaticResource SettingLabelStyle}" />
                                                                                </StackPanel>
                                                                                <TextBlock Text="{Binding DefaultText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Visibility="{Binding ShowsDefaultHint, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,3,0,0" />
                                                                                <TextBlock Text="{Binding RangeText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Visibility="{Binding HasRange, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,2,0,0" />
                                                                                <TextBlock Text="{Binding DependencyText}"
                                                                                           ToolTip="{Binding DependencyTechnicalText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Foreground="{StaticResource WarningBrush}"
                                                                                           Visibility="{Binding ShowInactiveDependencyWarning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,3,0,0" />
                                                                            </StackPanel>

                                                                            <controls:ConfigNumberEditor Grid.Column="1"
                                                                                                         ValueText="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                         Minimum="{Binding NumberMinimum}"
                                                                                                         Maximum="{Binding NumberMaximum}"
                                                                                                         Increment="{Binding NumberIncrement}"
                                                                                                         IsInteger="{Binding IsInteger}"
                                                                                                         IsEnabled="{Binding IsScalarEditorEnabled}" />

                                                                            <Border Grid.Column="2"
                                                                                    Style="{StaticResource ActivePillStyle}"
                                                                                    Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasExplicitOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="Active override"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="NoWrap" />
                                                                            </Border>
                                                                        </Grid>

                                                                        <Grid Visibility="{Binding UsesNumberTextEditor, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                              Style="{StaticResource ConfigTextRowStyle}">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="280" />
                                                                                <ColumnDefinition Width="240" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Margin="0,0,16,0"
                                                                                        VerticalAlignment="Center">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <CheckBox IsChecked="{Binding OverrideActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              Visibility="{Binding UsesOverrideStateSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                              Margin="0,0,10,0" />
                                                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                                                               Style="{StaticResource SettingLabelStyle}" />
                                                                                </StackPanel>
                                                                                <TextBlock Text="{Binding DefaultText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Visibility="{Binding ShowsDefaultHint, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,3,0,0" />
                                                                                <TextBlock Text="{Binding RangeText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Visibility="{Binding HasRange, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,2,0,0" />
                                                                                <TextBlock Text="{Binding DependencyText}"
                                                                                           ToolTip="{Binding DependencyTechnicalText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Foreground="{StaticResource WarningBrush}"
                                                                                           Visibility="{Binding ShowInactiveDependencyWarning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,3,0,0" />
                                                                            </StackPanel>

                                                                            <TextBox Grid.Column="1"
                                                                                     Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     IsEnabled="{Binding IsScalarEditorEnabled}"
                                                                                     Style="{StaticResource ConfigNumberTextBoxStyle}" />

                                                                            <Border Grid.Column="2"
                                                                                    Style="{StaticResource ActivePillStyle}"
                                                                                    Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasExplicitOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="Active override"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="NoWrap" />
                                                                            </Border>
                                                                        </Grid>

                                                                        <Grid Visibility="{Binding IsText, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                              Style="{StaticResource ConfigTextRowStyle}">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="280" />
                                                                                <ColumnDefinition Width="240" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Margin="0,0,16,0"
                                                                                        VerticalAlignment="Center">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <CheckBox IsChecked="{Binding OverrideActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              Visibility="{Binding UsesOverrideStateSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                              Margin="0,0,10,0" />
                                                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                                                               Style="{StaticResource SettingLabelStyle}" />
                                                                                </StackPanel>
                                                                                <TextBlock Text="{Binding DefaultText}"
                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                           Visibility="{Binding ShowsDefaultHint, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                           Margin="0,3,0,0" />
                                                                            </StackPanel>

                                                                            <TextBox Grid.Column="1"
                                                                                     Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     IsEnabled="{Binding IsScalarEditorEnabled}"
                                                                                     Style="{StaticResource ConfigTextTextBoxStyle}" />

                                                                            <Border Grid.Column="2"
                                                                                    Style="{StaticResource ActivePillStyle}"
                                                                                    Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasExplicitOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="Active override"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="NoWrap" />
                                                                            </Border>
                                                                        </Grid>

                                                                        <Grid Visibility="{Binding IsEnum, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                              Style="{StaticResource ConfigTextRowStyle}">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="280" />
                                                                                <ColumnDefinition Width="240" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <StackPanel Grid.Column="0"
                                                                                        Margin="0,0,16,0"
                                                                                        VerticalAlignment="Center">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <CheckBox IsChecked="{Binding OverrideActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              Visibility="{Binding UsesOverrideStateSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                              Margin="0,0,10,0" />
                                                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                                                               Style="{StaticResource SettingLabelStyle}" />
                                                                                </StackPanel>
                                                                            </StackPanel>

                                                                            <Grid Grid.Column="1">
                                                                                <ComboBox ItemsSource="{Binding Definition.Options}"
                                                                                          SelectedItem="{Binding SelectedOption}"
                                                                                          IsEnabled="{Binding IsScalarEditorEnabled}"
                                                                                          Visibility="{Binding HasStringOptions, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                          Style="{StaticResource ConfigComboBoxStyle}" />

                                                                                <ComboBox ItemsSource="{Binding Definition.ValueOptions}"
                                                                                          SelectedItem="{Binding SelectedValueOption}"
                                                                                          DisplayMemberPath="Label"
                                                                                          Visibility="{Binding HasValueOptions, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                          Style="{StaticResource ConfigComboBoxStyle}" />
                                                                            </Grid>

                                                                            <Border Grid.Column="2"
                                                                                    Style="{StaticResource ActivePillStyle}"
                                                                                    Margin="12,0,0,0"
                                                                                    Visibility="{Binding HasExplicitOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                <TextBlock Text="Active override"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold"
                                                                                           TextWrapping="NoWrap" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </Grid>
                                                                </Grid>

                                                                <StackPanel Visibility="{Binding IsTable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="{Binding Label}"
                                                                               Style="{StaticResource SettingLabelStyle}"
                                                                               Visibility="{Binding ShowInlineLabel, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                               Margin="0,0,0,8" />

                                                                    <TextBlock Text="{Binding DependencyText}"
                                                                               ToolTip="{Binding DependencyTechnicalText}"
                                                                               Style="{StaticResource HintTextStyle}"
                                                                               Foreground="{StaticResource WarningBrush}"
                                                                               Visibility="{Binding ShowInactiveDependencyWarning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                               Margin="0,0,0,8" />

                                                                    <Border Style="{StaticResource WarningBandStyle}"
                                                                            Visibility="{Binding IsWholeTable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                            Margin="0,0,0,12">
                                                                        <Grid>
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="Auto" />
                                                                            </Grid.RowDefinitions>
                                                                            <TextBlock Grid.Row="0"
                                                                                       Text="{Binding WholeTableWarning}"
                                                                                       Foreground="{StaticResource WarningBrush}"
                                                                                       FontSize="13"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="0,0,0,10" />
                                                                            <StackPanel Grid.Row="1"
                                                                                        Orientation="Horizontal">
                                                                                <CheckBox Content="Override whole table/list"
                                                                                          IsChecked="{Binding WholeTableEnabled}" />
                                                                                <Button Content="Add"
                                                                                        Command="{Binding AddRowCommand}"
                                                                                        IsEnabled="{Binding CanManageRows}"
                                                                                        Margin="14,0,0,0"
                                                                                        MinWidth="88" />
                                                                                <CheckBox Content="Confirm list replacement"
                                                                                          IsChecked="{Binding WholeTableConfirmed}"
                                                                                          Visibility="{Binding RequiresWholeTableConfirmation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                          Margin="14,0,0,0" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>

                                                                    <ItemsControl ItemsSource="{Binding Rows}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Style="{StaticResource ConfigTableRowStyle}">
                                                                                    <StackPanel>
                                                                                        <DockPanel Margin="0,0,0,10">
                                                                                            <Border Style="{StaticResource PillStyle}"
                                                                                                    DockPanel.Dock="Left"
                                                                                                    Visibility="{Binding IsIdentityLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                                <TextBlock Text="{Binding IdentityDisplayText}"
                                                                                                           Foreground="{StaticResource AccentHotBrush}"
                                                                                                           FontSize="12"
                                                                                                           FontWeight="SemiBold"
                                                                                                           ToolTip="{Binding TechnicalIdentity}"
                                                                                                           TextWrapping="NoWrap" />
                                                                                            </Border>
                                                                                            <TextBox Width="320"
                                                                                                     Text="{Binding Identity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                     ToolTip="{Binding TechnicalIdentity}"
                                                                                                     Visibility="{Binding IsIdentityEditable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                     Foreground="{StaticResource AccentHotBrush}"
                                                                                                     FontWeight="SemiBold" />
                                                                                        </DockPanel>

                                                                                        <ItemsControl ItemsSource="{Binding Cells}">
                                                                                            <ItemsControl.ItemsPanel>
                                                                                                <ItemsPanelTemplate>
                                                                                                    <WrapPanel />
                                                                                                </ItemsPanelTemplate>
                                                                                            </ItemsControl.ItemsPanel>
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate>
                                                                                                    <Border Style="{StaticResource ConfigTableCellStyle}">
                                                                                                        <StackPanel>
                                                                                                            <StackPanel Visibility="{Binding IsBoolean, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                                                <TextBlock Text="{Binding Column.Label}"
                                                                                                                           ToolTip="{Binding Column.Label}"
                                                                                                                           Style="{StaticResource CellLabelStyle}" />
                                                                                                                <StackPanel Style="{StaticResource BooleanSwitchClusterStyle}">
                                                                                                                    <CheckBox IsChecked="{Binding BooleanEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                              IsEnabled="{Binding BooleanEditorEnabled}"
                                                                                                                              Style="{StaticResource ConfigBooleanSwitchStyle}" />
                                                                                                                    <TextBlock Text="Enabled"
                                                                                                                               Style="{StaticResource SwitchLabelStyle}"
                                                                                                                               Margin="8,0,0,0" />
                                                                                                                </StackPanel>
                                                                                                            </StackPanel>

                                                                                                            <StackPanel Visibility="{Binding IsNonBoolean, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                                                                <TextBlock Text="{Binding Column.Label}"
                                                                                                                           ToolTip="{Binding Column.Label}"
                                                                                                                           Style="{StaticResource CellLabelStyle}" />
                                                                                                                <CheckBox IsChecked="{Binding OverrideActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                          Content="Enabled"
                                                                                                                          IsEnabled="{Binding ShowsOverrideActivation}"
                                                                                                                          Visibility="{Binding ShowsOverrideActivation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                                          Margin="0,0,0,6" />
                                                                                                                <TextBox Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                         IsEnabled="{Binding CanEditValue}"
                                                                                                                         Visibility="{Binding IsNumber, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                                         Style="{StaticResource TableNumberTextBoxStyle}" />
                                                                                                                <TextBox Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                         IsEnabled="{Binding CanEditValue}"
                                                                                                                         Visibility="{Binding IsText, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                                         Style="{StaticResource TableCellTextBoxStyle}" />
                                                                                                                <ComboBox ItemsSource="{Binding Column.Options}"
                                                                                                                          SelectedItem="{Binding SelectedOption}"
                                                                                                                          IsEnabled="{Binding CanEditValue}"
                                                                                                                          Visibility="{Binding IsEnum, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                                          Style="{StaticResource TableCellComboBoxStyle}" />
                                                                                                                <TextBlock Text="{Binding DefaultText}"
                                                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                                                           Visibility="{Binding ShowsDefaultHint, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                                           Margin="0,5,0,0" />
                                                                                                                <TextBlock Text="{Binding RangeText}"
                                                                                                                           Style="{StaticResource HintTextStyle}"
                                                                                                                           Visibility="{Binding HasRange, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                                                           Margin="0,2,0,0" />
                                                                                                            </StackPanel>
                                                                                                        </StackPanel>
                                                                                                    </Border>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
