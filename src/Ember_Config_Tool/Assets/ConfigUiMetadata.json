        { "key": "Steps", "label": "Steps", "valueType": "integer", "nullable": false },
        { "key": "Enabled", "label": "Enabled", "valueType": "boolean", "nullable": false },
        { "key": "Type", "label": "Type", "valueType": "string", "nullable": false, "readOnly": true },
        { "key": "Value", "label": "Setting Enabled", "valueType": "boolean", "nullable": false }
      ]
    },
