<UserControl x:Class="Ember_Config_Tool.Controls.ConfigNumberEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             HorizontalAlignment="Left"
             VerticalAlignment="Center">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="92" />
        </Grid.ColumnDefinitions>

        <Slider x:Name="PART_Slider"
                Grid.Column="0"
                Width="360"
                MinWidth="280"
                MaxWidth="440"
                Height="28"
                IsMoveToPointEnabled="True"
                Style="{StaticResource ConfigSliderStyle}"
                ValueChanged="Slider_ValueChanged"
                PreviewKeyDown="Slider_PreviewKeyDown"
                PreviewMouseWheel="Slider_PreviewMouseWheel" />

        <TextBox x:Name="PART_TextBox"
                 Grid.Column="2"
                 Width="92"
                 MinHeight="36"
                 TextAlignment="Center"
                 FontWeight="SemiBold"
                 Style="{StaticResource ConfigNumberEditorTextBoxStyle}"
                 LostKeyboardFocus="TextBox_LostKeyboardFocus"
                 KeyDown="TextBox_KeyDown" />
    </Grid>
</UserControl>
